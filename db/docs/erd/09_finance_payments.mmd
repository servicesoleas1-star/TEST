  }
  COUNTRY_CONFIGS {
    string country_code PK
    string country_name
  }
  MINIMUM_PAYOUT_CONFIGS {
    uuid config_id PK
    uuid user_id FK
    decimal min_amount
  }
  PAYOUT_BLOCKS {
    uuid block_id PK
