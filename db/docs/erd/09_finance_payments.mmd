    uuid user_id FK
    decimal gross_amount
    tx_status status
    uuid aggregator_id FK
    string external_tx_id
    string _more_columns_omitted
  }
  USER_COMMISSION_CONFIGS {
    uuid config_id PK
    uuid user_id FK
    campaign_type campaign_type
    uuid configured_by FK
  }
  COMMISSION_CONFIGS {
    uuid config_id PK
    commission_type type
    decimal floor_amount
    uuid modified_by FK
  }
  PAYOUT_REQUESTS {
    uuid payout_id PK
    uuid user_id FK
    decimal requested_amount
    decimal net_amount
    uuid aggregator_id FK
    payout_status status
  }
  ORGANIZER_BALANCES {
    uuid balance_id PK
    uuid user_id FK
    decimal available_amount
    decimal reserved_amount
  }
