# Copier ce fichier en .env et renseigner les vraies valeurs.
# Ne jamais committer le fichier .env réel.

# ========================================
# SERVEUR
# ========================================
PORT=4000
NODE_ENV=development
DEBUG=false

# ========================================
# BASE DE DONNÉES
# ========================================
# Connexion PostgreSQL (base déjà créée dans le repo db/)
DATABASE_URL=postgresql://user:password@localhost:5432/liboka_vote_dev

# ========================================
# AUTHENTIFICATION & SÉCURITÉ
# ========================================
# Domaines autorisés pour redirect_to (anti open-redirect)
ALLOWED_REDIRECT_HOST=localhost:5173

# Coût bcrypt (12 minimum recommandé — chaque +1 double le temps de calcul)
BCRYPT_COST=12

# Verrouillage de compte après échecs de connexion
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Vérification email
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
EMAIL_RESEND_COOLDOWN_SECONDS=60

# JWT Secret (générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_jwt_secret_here_generate_with_crypto
JWT_EXPIRES_IN=7d

# ========================================
# PAIEMENT — Orange Money Cameroun
# ========================================
# Récupérer auprès d'Orange Money
ORANGE_MONEY_API_KEY=your_merchant_id_here
ORANGE_MONEY_API_SECRET=your_api_secret_here

# URL de base du backend (pour les webhooks)
BACKEND_URL=http://localhost:4000

# ========================================
# EMAIL (SMTP)
# ========================================
# Optionnel : à configurer pour l'envoi réel
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=noreply@moledievents.cm

# ========================================
# CONFIGURATION PAIEMENT (rechargeable à chaud via YAML)
# ========================================
# Le fichier config/payment/aggregators.yaml est chargé automatiquement
# par ConfigManager (lib/payment/configManager.js). Pas de variable
# d'environnement nécessaire, tout est dans le YAML (les clés API
# ORANGE_MONEY_API_KEY / ORANGE_MONEY_API_SECRET sont définies plus haut).